# =============================================================================
# MediConnect — environment template
# Copy to `.env` at the repo root. Next.js apps (web, admin, video) also load this
# file via `next.config.mjs`; optional per-app overrides in `apps/<app>/.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required for Prisma)
# -----------------------------------------------------------------------------
# Local Docker stack: see infra/docker/docker-compose.yml (default user/db/pass: mediconnect)
# Prisma CLI (`pnpm db:push`, migrate, seed) runs from packages/db and loads env in this order:
#   1) repo root .env (this file)  2) packages/db/.env (overrides)
DATABASE_URL="postgresql://mediconnect:mediconnect@localhost:5432/mediconnect"

# -----------------------------------------------------------------------------
# Auth simulation — @mediconnect/auth (no login UI; dev/demo only)
# -----------------------------------------------------------------------------
# First user in DB with this role is used as the current user (after seed: patient@, doctor@, admin@).
SIMULATED_ROLE=PATIENT
# Optional: pin to a specific User.id (overrides SIMULATED_ROLE lookup)
# SIMULATED_USER_ID=

# -----------------------------------------------------------------------------
# Google OAuth (Calendar / Gmail — when you wire E3)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI — Claude (SOAP, ai-agent, etc.)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Optional override; default in code: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Embeddings / RAG — Hugging Face Inference API (hospital KB + video consult)
# -----------------------------------------------------------------------------
# Token: https://huggingface.co/settings/tokens — used for router feature-extraction
HUGGINGFACE_API_TOKEN=
# Alternative env name (same value)
HF_TOKEN=
# After setting either token, run: pnpm --filter @mediconnect/knowledge-base test:hf
# Default: BAAI/bge-large-en-v1.5 (1024-dim; must match DB vector column)
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Must match HF model output and packages/db migration vector(1024)
EMBEDDING_DIMENSIONS=1024
# BGE asymmetric query prefix; set empty to disable (passage chunks stay unprefixed)
# BGE_QUERY_PREFIX=Represent this sentence for searching relevant passages: 
#
# Patient-education KB (ai-agent /chat): load bundled plain-English articles + embeddings
# pnpm seed:patient-kb

# Featherless — OpenAI-compatible chat (ai-agent KB demo + video RAG answers)
LLM_BASE_URL=https://api.featherless.ai/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3-14B

# Legacy / optional OpenAI for other tools
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Video — Beyond Presence + LiveKit (apps/video)
# -----------------------------------------------------------------------------
# REST API (Beyond Presence / bey.dev)
BEYOND_PRESENCE_API_KEY=
BEYOND_PRESENCE_API_URL=https://api.bey.dev

# Required with API key for speech-to-video: avatar + YOUR LiveKit project
BEYOND_PRESENCE_AVATAR_ID=
# LiveKit Cloud: often wss://YOUR_PROJECT.livekit.cloud — we send https:// to Beyond Presence (iframe cannot load wss://)
LIVEKIT_URL=
# Server API credentials (apps/video): mint per-appointment room JWTs + dispatch the patient voice agent
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Legacy only: single static viewer token (cannot scope to per-appointment room — dev / demos)
LIVEKIT_TOKEN=

# Run alongside video when using Beyond Presence + patient voice agent (see docs/beyond-presence-rag-bridge.md)
# pnpm --filter @mediconnect/livekit-patient-agent dev
# Needs: LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET, LLM_*, ELEVENLABS_*, DATABASE_URL, HF_TOKEN (embeddings)

# -----------------------------------------------------------------------------
# Voice — ElevenLabs (E4 read-aloud; not required for E1)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
# Voice from elevenlabs.io — e.g. a premade voice id from the web app
ELEVENLABS_VOICE_ID=
# Optional; default eleven_multilingual_v2
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# -----------------------------------------------------------------------------
# Medical / knowledge APIs (packages/knowledge-base)
# -----------------------------------------------------------------------------
NCBI_API_KEY=
OPENFDA_API_KEY=
DRUGBANK_API_KEY=
# Optional; default https://api.drugbank.com/v1
DRUGBANK_BASE_URL=https://api.drugbank.com/v1
# Optional NIH ICD tables token if you use authenticated lookups
ICD_API_TOKEN=

# -----------------------------------------------------------------------------
# Supabase (pgvector — when you wire hosted vector store)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# Object storage — GCS or local MinIO (readme stack)
# -----------------------------------------------------------------------------
GCS_BUCKET_NAME=mediconnect-documents-local
GCS_ENDPOINT=http://localhost:9000
GCS_ACCESS_KEY=minioadmin
GCS_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# Public / client-side
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional shared API base for @mediconnect/api-client
NEXT_PUBLIC_API_BASE_URL=
