{
  "name": "@mediconnect/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate",
    "lint": "cross-env DATABASE_URL=postgresql://localhost:5432/mediconnect prisma validate",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/node": "^22.10.2",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
