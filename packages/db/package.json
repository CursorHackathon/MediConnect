{
  "name": "@mediconnect/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate",
    "lint": "cross-env DATABASE_URL=postgresql://localhost:5432/mediconnect prisma validate",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "db:push": "dotenv -e ../../.env -e .env -- prisma db push",
    "db:migrate": "dotenv -e ../../.env -e .env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env -e .env -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env -e .env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -e .env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -e .env -- tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
