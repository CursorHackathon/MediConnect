# Copy to `.env` in the repo root (same folder as docker-compose.yml) for `docker compose up`.
# Docker Compose loads this file automatically.

NEXTAUTH_SECRET=change-me-use-openssl-rand-base64-32

# Optional: AI / embeddings (Doctor AI app, video KB)
# HF_TOKEN=
# OPENAI_API_KEY=
# LLM_API_KEY=

# Optional: LiveKit (video app — runtime)
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
