# Copy to `infra/docker/.env` (same folder as docker-compose.yml).
# Compose reads this path via `env_file: .env` in docker-compose.yml — no --env-file CLI flag needed.
# Keep only infra vars here (Postgres, Redis, MinIO, Mailhog ports/credentials).
# Start from repo root: docker compose -f infra/docker/docker-compose.yml up -d

COMPOSE_PROJECT_NAME=mediconnect

POSTGRES_USER=mediconnect
POSTGRES_PASSWORD=mediconnect
POSTGRES_DB=mediconnect
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
