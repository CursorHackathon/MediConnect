{
  "name": "@mediconnect/livekit-patient-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx src/main.ts dev",
    "start": "dotenv -e ../../.env -- tsx src/main.ts start",
    "download-files": "dotenv -e ../../.env -- tsx src/main.ts download-files",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@livekit/agents": "1.2.0",
    "@livekit/rtc-node": "0.13.24",
    "@livekit/agents-plugin-bey": "1.2.0",
    "@livekit/agents-plugin-elevenlabs": "1.2.0",
    "@livekit/agents-plugin-livekit": "1.2.0",
    "@livekit/agents-plugin-openai": "1.2.0",
    "@livekit/agents-plugin-silero": "1.2.0",
    "@mediconnect/db": "workspace:*",
    "@mediconnect/knowledge-base": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
