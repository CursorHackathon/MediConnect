{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@mediconnect/db": ["../../packages/db/src/index.ts"],
      "@mediconnect/ui": ["../../packages/ui/src/index.ts"],
      "@mediconnect/types": ["../../packages/types/src/index.ts"],
      "@mediconnect/auth": ["../../packages/auth/src/index.ts"],
      "@mediconnect/api-client": ["../../packages/api-client/src/index.ts"],
      "@mediconnect/knowledge-base": ["../../packages/knowledge-base/src/index.ts"],
      "@mediconnect/i18n": ["../../packages/i18n/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
